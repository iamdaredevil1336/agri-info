{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static", "config": { "exclude": ["server.js"] } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(crops|seeds|seasons|soils)\\.html", "dest": "/$1.html" },
    { "src": "/(style\\.css|api\\.js|main\\.js|crops\\.js|seeds\\.js|seasons\\.js|soils\\.js|data\\.js)", "dest": "/$1" }
  ]
}
